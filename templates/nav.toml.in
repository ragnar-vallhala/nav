# Nav Configuration File
[project]
name = "{{PROJECT_NAME}}"
version = "0.1.0"
# "executable" builds firmware; "library" builds a reusable static archive.
type = "executable"

[target]
arch = "cortex-m4"
vendor = "stm32"
board = "nucleo_f401re"

[build]
backend = "cmake"

# Libraries this project links against. Each is a nav library project, referenced
# by a local path or a git URL:
# [dependencies]
# mylib   = { path = "../mylib" }
# sensors = { git = "https://example.com/sensors.git", ref = "main" }

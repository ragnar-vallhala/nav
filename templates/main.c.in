#define CORTEX_M4
#include "navhal.h"

int main(void) {
    // 1. Bootstrap the HAL timebase (1 ms tick).
    hal_timebase_init(1000);

    // 2. Open UART2 for communication.
    hal_uart_config_t uart_cfg = {.baudrate = 115200};
    hal_uart_init(HAL_UART_2, &uart_cfg);

    hal_uart_write_string(HAL_UART_2, "System Up.\r\n");

    while (1) {
        // Main logic loop
    }

    return 0;
}

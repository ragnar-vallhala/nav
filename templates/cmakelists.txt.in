cmake_minimum_required(VERSION 3.20)

# Nav-generated board context. Generated by `nav build` from share/nav/boards/.
# Must be included BEFORE project() so toolchain settings (CMAKE_C_COMPILER
# etc.) derived from it take effect for CMake's compiler-detection probe.
if(EXISTS "${CMAKE_BINARY_DIR}/nav-board.cmake")
    include("${CMAKE_BINARY_DIR}/nav-board.cmake")
endif()

set(CMAKE_SYSTEM_NAME Generic)
if(NAV_BOARD_ARCH)
    set(CMAKE_SYSTEM_PROCESSOR ${NAV_BOARD_ARCH})
endif()

if(NAV_BOARD_COMPILER)
    set(CMAKE_C_COMPILER   ${NAV_BOARD_COMPILER})
    set(CMAKE_ASM_COMPILER ${NAV_BOARD_COMPILER})
    string(REGEX REPLACE "gcc$" "" NAV_TOOLCHAIN_PREFIX "${NAV_BOARD_COMPILER}")
    set(CMAKE_OBJCOPY     ${NAV_TOOLCHAIN_PREFIX}objcopy)
    set(CMAKE_BINARY_SIZE ${NAV_TOOLCHAIN_PREFIX}size)
endif()

# Nav-resolved registry dependencies (libraries + toolchain) from nav.lock.
# Included before project() so a registry-provided compiler takes effect for
# CMake's compiler-detection probe.
if(EXISTS "${CMAKE_BINARY_DIR}/nav-deps.cmake")
    include("${CMAKE_BINARY_DIR}/nav-deps.cmake")
endif()

# A registry toolchain (e.g. `nav add arm-none-eabi-gcc`) overrides the board's
# bare compiler name with a concrete cached path.
if(NAV_DEPS_COMPILER)
    set(CMAKE_C_COMPILER   ${NAV_DEPS_COMPILER})
    set(CMAKE_ASM_COMPILER ${NAV_DEPS_COMPILER})
    string(REGEX REPLACE "gcc$" "" NAV_TOOLCHAIN_PREFIX "${NAV_DEPS_COMPILER}")
    set(CMAKE_OBJCOPY     ${NAV_TOOLCHAIN_PREFIX}objcopy)
    set(CMAKE_BINARY_SIZE ${NAV_TOOLCHAIN_PREFIX}size)
endif()
set(CMAKE_TRY_COMPILE_TARGET_TYPE STATIC_LIBRARY)

project({{PROJECT_NAME}} C CXX ASM)

set(CMAKE_EXPORT_COMPILE_COMMANDS ON)

# 1. Sync global configuration to dependency path
if(EXISTS "${CMAKE_CURRENT_SOURCE_DIR}/.config")
    message(STATUS "[Nav] Locking active configuration context...")
    configure_file(
        "${CMAKE_CURRENT_SOURCE_DIR}/.config"
        "${CMAKE_CURRENT_SOURCE_DIR}/extern/NavHAL/.config"
        COPYONLY
    )
else()
    message(WARNING "[Nav] Master '.config' not detected in project root! Utilizing ambient internal repository defaults.")
endif()

# 2. Add NavHAL Dependency Framework
add_subdirectory(extern/NavHAL)

# 2a. Nav library dependencies (from nav.toml [dependencies]). nav resolves the
#     transitive graph and writes build/nav-deps-libs.cmake, which
#     add_subdirectory()s each library and wires their link edges. Libraries
#     compile their NavHAL-dependent sources against this include path.
set(NAV_NAVHAL_INCLUDE_DIR "${CMAKE_CURRENT_SOURCE_DIR}/extern/NavHAL/include")
if(EXISTS "${CMAKE_BINARY_DIR}/nav-deps-libs.cmake")
    include("${CMAKE_BINARY_DIR}/nav-deps-libs.cmake")
endif()

# 3. Inherit Dynamic Target Environment Variables (NavHAL exports BOARD,
#    FLASHER, FLASH_ADDRESS for backward compatibility with its config flow).
include("${CMAKE_BINARY_DIR}/config.cmake")

# 4. Declare user application target
add_executable(${PROJECT_NAME} src/main.c)

# 5. Apply board-derived compilation flags.
if(NAV_BOARD_COMPILE_FLAGS)
    target_compile_options(${PROJECT_NAME} PRIVATE ${NAV_BOARD_COMPILE_FLAGS})
endif()

# 6. Hardware-Bound Linker Directives.
target_link_options(${PROJECT_NAME} PRIVATE
  "-T" "${CMAKE_CURRENT_SOURCE_DIR}/extern/NavHAL/src/board/${BOARD}/linker.ld"
  "-nostdlib"
  "--specs=nosys.specs"
  ${NAV_BOARD_LINK_FLAGS}
)

# 7. Inherit linkage rules (Whole Archive mandatory for static HAL exports)
target_link_libraries(${PROJECT_NAME} PRIVATE
  -Wl,--start-group
    -Wl,--whole-archive hal -Wl,--no-whole-archive
    -lgcc
  -Wl,--end-group
)

# 8. Bind includes
target_include_directories(${PROJECT_NAME} PUBLIC
    include
    extern/NavHAL/include
)

# 8a. Registry library inputs (from nav-deps.cmake): headers, archive search
#     dirs, and the resolved static archives themselves.
if(NAV_DEPS_INCLUDE_DIRS)
    target_include_directories(${PROJECT_NAME} PUBLIC ${NAV_DEPS_INCLUDE_DIRS})
endif()
if(NAV_DEPS_LINK_DIRS)
    target_link_directories(${PROJECT_NAME} PRIVATE ${NAV_DEPS_LINK_DIRS})
endif()
if(NAV_DEPS_LIBRARIES)
    target_link_libraries(${PROJECT_NAME} PRIVATE ${NAV_DEPS_LIBRARIES})
endif()

# 8b. Nav library dependencies built from source (nav-deps-libs.cmake). Each is
#     a static target whose PUBLIC include dirs propagate here automatically.
if(NAV_DEP_TARGETS)
    target_link_libraries(${PROJECT_NAME} PRIVATE ${NAV_DEP_TARGETS})
endif()

# 9. Flash target support. Prefer Nav-resolved flasher; fall back to NavHAL's
#    BOARD-derived FLASHER / FLASH_ADDRESS when the catalog leaves them blank.
set(NAV_RESOLVED_FLASHER "${FLASHER}")
set(NAV_RESOLVED_FLASH_ADDRESS "${FLASH_ADDRESS}")
if(NAV_BOARD_FLASH_TOOL)
    set(NAV_RESOLVED_FLASHER "${NAV_BOARD_FLASH_TOOL}")
endif()
if(NAV_BOARD_FLASH_ADDRESS)
    set(NAV_RESOLVED_FLASH_ADDRESS "${NAV_BOARD_FLASH_ADDRESS}")
endif()
if(NAV_RESOLVED_FLASHER AND NAV_RESOLVED_FLASH_ADDRESS)
    add_custom_target(flash
      COMMAND ${CMAKE_OBJCOPY} -O binary $<TARGET_FILE:${PROJECT_NAME}> ${CMAKE_CURRENT_BINARY_DIR}/${PROJECT_NAME}.bin
      COMMAND ${NAV_RESOLVED_FLASHER} write ${CMAKE_CURRENT_BINARY_DIR}/${PROJECT_NAME}.bin ${NAV_RESOLVED_FLASH_ADDRESS}
      DEPENDS ${PROJECT_NAME}
      COMMENT "Pumping Binary payload onto board..."
    )
endif()

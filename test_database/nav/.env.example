# ==========================================
# Nav Registry Node Environment Configuration
# ==========================================

# API Server Context
PORT=8081
JWT_SECRET=REPLACE_ME_WITH_RANDOM_STRING

# Relational Storage (PostgreSQL)
DB_HOST=database
DB_USER=nav_admin
DB_PASSWORD=nav_secure_password_change_me
DB_NAME=nav_registry

# Object Storage (MinIO / S3)
MINIO_ENDPOINT=storage:9000
MINIO_ACCESS_KEY=navroot
MINIO_SECRET_KEY=navpassword123

# SMTP Relay (Mail Transfer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
GOOGLE_APP_PASSWORD=your-app-password-from-google
EMAIL_FROM_NAME=Nav Registry Authority
